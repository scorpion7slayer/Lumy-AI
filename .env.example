# Toutes les clés restent côté serveur dans les routes TanStack Start.
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=Lumy
KILO_API_KEY=
OPENCODE_API_KEY=
NVIDIA_API_KEY=

# Vérification obligatoire des adresses e-mail. Ces valeurs ne sont jamais
# exposées ni modifiables depuis l’interface administrateur.
APP_URL=http://localhost:3000
APP_TIME_ZONE=Europe/Brussels
RESEND_API_KEY=
RESEND_FROM_EMAIL="Lumy AI <verification@example.com>"
SUPER_ADMIN_EMAIL=

# MySQL est utilisé uniquement dans les routes serveur.
DB_HOST=
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASSWORD=
